{
  "expo": {
    "name": "Mini Business",
    "slug": "mini-business-listing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "minibusiness",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edkang.minibusinesslisting",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to attach a city to your business listing.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.edkang.minibusinesslisting",
      "adaptiveIcon": {
        "backgroundColor": "#7C3AED",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Mini Business Listing to use your location to attach a city to your business listing."
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2b92d69f-44a0-4797-bf70-94645f12d914"
      }
    },
    "owner": "abosedekikelomo408"
  }
}
